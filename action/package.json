{
  "name": "action",
  "version": "1.4.7",
  "description": "Bump the version of a package.json files using bump-please",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "bundle": "yarn package",
    "package": "yarn rollup --config rollup.config.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@actions/core": "^2.0.1",
    "bump-please-core": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^22.0.0",
    "rollup": "^4.46.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
